{
  "name": "hn-jobs-data",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.30.3",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "pipeline": "node --env-file-if-exists=.env --import tsx/esm scripts/run.ts",
    "fetch": "node --env-file-if-exists=.env --import tsx/esm scripts/run-fetch.ts",
    "analyze": "node --env-file-if-exists=.env --import tsx/esm scripts/run-analyze.ts",
    "backfill": "node --env-file-if-exists=.env --import tsx/esm scripts/run-backfill.ts",
    "index": "node --import tsx/esm scripts/run-index.ts",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.5.0",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-unused-imports": "^4.4.1",
    "eslint-plugin-zod": "^3.5.0",
    "prettier": "^3.8.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.0"
  }
}
